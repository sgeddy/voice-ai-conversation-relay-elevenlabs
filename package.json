    "dotenv": "^17.4.2",
    "fastify": "^5.8.5",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "twilio": "^5.13.1"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
