# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Anthropic (default LLM)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-7

# ElevenLabs (TTS)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# Optional: swap LLM to OpenAI
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o

# Server
PORT=3000
PUBLIC_BASE_URL=https://your-ngrok-subdomain.ngrok.app

# Telemetry (optional)
OTEL_EXPORTER_OTLP_ENDPOINT=
LOG_LEVEL=info
