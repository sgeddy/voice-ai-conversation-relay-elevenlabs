# Twilio — TWILIO_AUTH_TOKEN and TWILIO_ACCOUNT_SID are REQUIRED to receive
# calls. Twilio webhooks are validated by HMAC-SHA1 signature against the
# auth token; any request to /twiml without a valid signature is rejected
# with 403. The AccountSid in the webhook body must also match
# TWILIO_ACCOUNT_SID.
#
# TWILIO_PHONE_NUMBER is the bench's "from" number (synthetic caller).
# BENCH_AGENT_NUMBER is the destination — your agent's CR-configured Twilio
# number that the harness places calls to.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
BENCH_AGENT_NUMBER=

# Anthropic (default LLM — Haiku 4.5 for lowest latency + cost on voice)
# Alternatives: claude-sonnet-4-6 (more reasoning depth, moderate latency)
#               claude-opus-4-7 (max reasoning, slowest, most expensive)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ElevenLabs — used by Conversation Relay's internal TTS pipeline.
# ELEVENLABS_API_KEY is optional at runtime (CR handles the ElevenLabs
# integration). Required only for direct ElevenLabs API calls (e.g., the
# benchmark harness making out-of-band latency measurements).
# ELEVENLABS_VOICE_ID defaults to Twilio's bundled voice if unset; override
# with a voice ID from your account.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# STT provider used by Conversation Relay. "Deepgram" or "Google".
# Deepgram is CR's default for new accounts and typically has lower latency.
TRANSCRIPTION_PROVIDER=Deepgram

# Server
PORT=3000
# PUBLIC_BASE_URL must be the EXACT URL Twilio uses to reach /twiml — used
# for signature verification. Behind Caddy/nginx, this is your public HTTPS
# URL, NOT the localhost address.
#   dev:   https://<your-ngrok>.ngrok.app
#   prod:  https://voice-ai.samueleddy.com
PUBLIC_BASE_URL=

# Service gates
# SERVICE_ACTIVE=false soft-disables /twiml + CR WebSocket without stopping
# the host. Useful for "off when idle" mode on a long-lived deploy.
SERVICE_ACTIVE=true
# DEV_BYPASS_SIGNATURE=true skips Twilio webhook signature validation. ONLY
# use for local curl-based smoke tests. NEVER set in production.
DEV_BYPASS_SIGNATURE=false

# Optional: OTEL endpoint for exporting structured metrics
OTEL_EXPORTER_OTLP_ENDPOINT=
LOG_LEVEL=info

# Set automatically by the AWS deploy script — do not edit manually.
GIT_SHA=
